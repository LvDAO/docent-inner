# Deployment identity and host bindings.
# Use a unique project name when multiple Docent deployments share one machine.
COMPOSE_PROJECT_NAME=docent
DOCENT_WEB_BIND_ADDRESS=0.0.0.0
DOCENT_WEB_PORT=3000
DOCENT_SERVER_PORT=8888
DOCENT_DATA_BIND_ADDRESS=127.0.0.1

# Conservative defaults for a small machine. Increase only after measuring load.
DOCENT_BACKEND_WORKERS=2
DOCENT_WORKER_PROCESSES=1
DOCENT_PG_POOL_SIZE=5
DOCENT_PG_MAX_OVERFLOW=5

# LLM provider configuration.
# Use "custom" for a generic OpenAI-compatible endpoint. In Docker Compose,
# use host.docker.internal instead of localhost for a model server on the host.
DOCENT_LLM_PROVIDER=deepseek
DOCENT_LLM_BASE_URL=https://api.deepseek.com
DOCENT_LLM_API_KEY=<KEY_OR_DUMMY_FOR_LOCAL_ENDPOINT>
DOCENT_LLM_FLASH_MODEL=deepseek-v4-flash
DOCENT_LLM_PRO_MODEL=deepseek-v4-pro
DOCENT_LLM_CONTEXT_WINDOW=1000000

# Embeddings use a separate OpenAI-compatible endpoint. Local servers that do
# not enforce authentication still require a non-empty dummy key.
DOCENT_EMBEDDING_BASE_URL=
DOCENT_EMBEDDING_API_KEY=<KEY_OR_DUMMY_FOR_LOCAL_ENDPOINT>
DOCENT_EMBEDDING_MODEL=text-embedding-3-small
DOCENT_EMBEDDING_DIMENSIONS=512

# Optional Hodoscope-only embedding overrides. Use these when Hodoscope should
# use a different model without changing the 512-dimensional transcript table.
DOCENT_HODOSCOPE_EMBEDDING_MODEL=
DOCENT_HODOSCOPE_EMBEDDING_DIMENSIONS=
DOCENT_HODOSCOPE_EMBEDDING_BASE_URL=
DOCENT_HODOSCOPE_EMBEDDING_API_KEY=

# Optional per-feature model overrides. Blank values inherit FLASH or PRO.
DOCENT_LLM_CHAT_MODEL=
DOCENT_LLM_JUDGE_MODEL=
DOCENT_LLM_JUDGE_FALLBACK_MODEL=
DOCENT_LLM_SUMMARIZE_AGENT_ACTIONS_MODEL=
DOCENT_LLM_HODOSCOPE_ACTION_SUMMARY_MODEL=
DOCENT_LLM_GROUP_ACTIONS_MODEL=
DOCENT_LLM_OBSERVATIONS_MODEL=
DOCENT_LLM_SEARCH_MODEL=
DOCENT_LLM_REFINE_MODEL=
DOCENT_LLM_REFINEMENT_MESSAGE_MODEL=
DOCENT_LLM_CLUSTER_MODEL=
DOCENT_LLM_CLUSTER_ASSIGN_MODEL=
DOCENT_LLM_CLUSTER_ASSIGN_STRONG_MODEL=
DOCENT_LLM_GENERATE_QUERIES_MODEL=
DOCENT_LLM_SUMMARIZE_INTENDED_SOLUTION_MODEL=

# Backward-compatible provider aliases and local cache.
DEEPSEEK_API_KEY=
LLM_CACHE_PATH=

# Bundled Postgres. Compose replaces HOST/PORT inside application containers.
DOCENT_PG_USER=docent_user
DOCENT_PG_PASSWORD=docent_password
DOCENT_PG_HOST=localhost
DOCENT_PG_PORT=5432
DOCENT_PG_DATABASE=docent_db

# Bundled Redis. Username is only needed for an external ACL-enabled Redis.
DOCENT_REDIS_HOST=localhost
DOCENT_REDIS_PORT=6379
DOCENT_REDIS_USER=
DOCENT_REDIS_PASSWORD=
DOCENT_REDIS_TLS=false

# Maximum runtime for one background job, in seconds.
DOCENT_WORKER_JOB_TIMEOUT_SECONDS=1800

# Same-origin Web/API traffic needs no CORS or cookie-domain override.
DOCENT_CORS_ORIGINS=
COOKIE_DOMAIN=

# Optional observability settings. Leave DEPLOYMENT_ID blank for local use.
DEPLOYMENT_ID=
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_API_HOST=
