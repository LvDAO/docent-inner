# Secrets and repository metadata never belong in an image build context.
.env
.env.*
.git/
.gitignore

# Local environments, dependencies, and generated output.
.venv/
**/.venv/
node_modules/
**/node_modules/
**/.next/
__pycache__/
**/__pycache__/
*.py[cod]
*.tsbuildinfo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
build/
dist/
site/
coverage/
htmlcov/

# Developer-only material is not used by either Dockerfile.
.vscode/
docs/
examples/
tests/
*.ipynb
task_plan.md
notes.md
*.log
.DS_Store
